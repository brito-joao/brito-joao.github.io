      target_content: "            {/* Section 3: The Foundation (Faith & Community) */}\n            <section\n              id=\"foundation\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-sky-400/20 text-sky-400 rounded-full\">\n                  THE FOUNDATION\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">03. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Driven by Purpose.<br/>\n                <span className=\"text-stone-500\">Street preaching across Lisbon.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                True power is not merely compiled in code or physical resistors; it is shared through the truth. \n                My entire philosophy is deeply rooted in absolute faith. You can find me regularly on the streets of Lisboa, sharing the Gospel and connecting with thinkers from all cultures. \n                In addition to ministry, I dedicate regular intervals to teaching Portuguese to foreign seekers, helping them lay roots in our country.\n              </p>\n\n              <div className=\"mt-8 bg-white/1 border border-white/5 rounded-xl p-4 flex flex-col gap-3 w-full\">\n                <span className=\"text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Ongoing Lisbon Assignments</span>\n                <div className=\"flex justify-between items-center text-xs text-white pb-2 border-b border-white/5 font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Sparkles className=\"w-3.5 h-3.5 text-sky-400\" /> Street Ministry Preach</span>\n                  <span className=\"text-muted-foreground\">Baixa-Chiado & Rossio</span>\n                </div>\n                <div className=\"flex justify-between items-center text-xs text-white font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Users className=\"w-3.5 h-3.5 text-sky-400\" /> Portuguese Instruction</span>\n                  <span className=\"text-muted-foreground\">Conversational Integration</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 4: The Discipline (Fitness & Mindset) */}\n            <section\n              id=\"discipline\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-red-500/20 text-red-400 rounded-full\">\n                  THE DISCIPLINE\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">04. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Discipline in the Iron.<br/>\n                <span className=\"text-stone-500\">Crushing the 140kg bench press limit.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                The mind designs beautiful conceptual paradigms, but the body must possess the grit to execute them under immense stress. \n                Physical training represents my absolute daily crucible. Bench-pressing 140kg isn&apos;t just a mechanical statistic&mdash;it stands as raw evidence that consistency, patience, and unwavering intensity yield undeniable performance. \n                This exact tenacity translates seamlessly into my engineering studies and code refinement.\n              </p>\n\n              <div className=\"mt-8 flex gap-6 items-center flex-wrap\">\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-muted-foreground uppercase\">Bench Press Personal Best</span>\n                  <span className=\"font-display text-5xl text-red-400 leading-none mt-1\">140<sup className=\"text-xl\">KG</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-500 uppercase mt-1\">308 Pounds Solid Steel</span>\n                </div>\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-muted-foreground uppercase\">Daily Grind Consistency</span>\n                  <span className=\"font-display text-5xl text-white leading-none mt-1\">100<sup className=\"text-xl\">%</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-500 uppercase mt-1\">Zero Days Skipped / Absolute Focus</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 5: The Invitation (CTA / Form Link) */}\n            <section\n              id=\"invitation\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pb-20 scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-amber-500/20 text-amber-500 rounded-full\">\n                  THE INVITATION\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">05. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-5xl sm:text-7xl text-white tracking-normal leading-[0.95] max-w-xl\">\n                Let&apos;s Build Something Exceptional.\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                If you are inspired by this custom interactive portfolio and desire an elite, premium digital brand space that captures your unique story, or if you simply are eager to connect over engineering, faith, or strength training: my inbox is permanently configured to receive you.\n              </p>\n\n              <div className=\"flex flex-col sm:flex-row gap-4 mt-10 w-full max-w-md\">\n                <button\n                  id=\"invitation-contact-btn\"\n                  onClick={() => setIsContactOpen(true)}\n                  className=\"px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest bg-white text-black hover:bg-stone-200 transition-all flex items-center justify-center gap-1.5 cursor-pointer border-none\"\n                >\n                  Start a Conversation\n                </button>\n                <a\n                  id=\"invitation-ig-btn\"\n                  href=\"https://www.instagram.com/joao.brito_\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"liquid-glass px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest text-white hover:scale-[1.02] transition-transform flex items-center justify-center gap-2 border-none\"\n                >\n                  Direct Instagram DM\n                </a>\n              </div>\n            </section>\n\n          </div>\n\n          {/* Right Hemisphere: Persistent high-end visual column */}\n          <div className=\"col-span-12 lg:col-span-5 h-[400px] lg:h-screen lg:sticky lg:top-0 flex flex-col justify-center items-center pointer-events-auto\">\n            {/* 3D Interactive Model Canvas container */}\n            <div className=\"w-full h-[320px] lg:h-[60%] flex items-center justify-center relative\">\n              <InteractiveModel activeSection={activeSection} />\n            </div>\n            \n            {/* Scroll Indicator helper text */}\n            <div className=\"mt-4 font-mono text-[10px] text-muted-foreground/30 uppercase tracking-[0.2em] hidden lg:block select-none animate-pulse\">\n              [ SCROLL TO MORPH VECTOR MATRIX ]\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Pinned Bottom-Left Zone: Dedicated Interactive Widget placement */}\n      <div className=\"fixed bottom-6 left-6 md:left-24 z-30 max-w-[340px] pointer-events-auto hidden md:block select-none hover:translate-y-[-4px] transition-all duration-300\">\n        <InteractiveWidget onTriggerPulse={triggerAnimationPulse} />\n      </div>\n\n      {/* Mobile-only collapsed Bottom Widget (Collapsible for spacing) */}\n      <div className=\"w-full px-6 py-6 border-t border-white/5 bg-[#001F33]/80 backdrop-blur-xl md:hidden relative z-30 selection:bg-white selection:text-black mt-10\">\n        <span className=\"text-[10px] font-mono text-stone-500 uppercase tracking-widest mb-2 block\">Interactive Ambient Center</span>\n        <InteractiveWidget onTriggerPulse={triggerAnimationPulse} />\n      </div>\n\n      {/* Slideout Modals Layer */}\n      <ContactModal\n        isOpen={isContactOpen}\n        onClose={() => setIsContactOpen(false)}\n      />\n      <ProjectHub\n        isOpen={isHubOpen}\n        onClose={() => setIsHubOpen(false)}\n        onContactClick={() => setIsContactOpen(true)}\n      />"
      replacement_content: "            {/* Section 3: The Foundation (Faith & Community) */}\n            <section\n              id=\"foundation\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-sky-400/20 text-sky-600 rounded-full\">\n                  A FUNDA\303\207\303\203O\n                </span>\n                <span className=\"text-[10px] font-mono text-stone-400\">CAP\303\215TULO 03</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-stone-900 tracking-wide leading-tight\">\n                Guiado por Prop\303\263sito.<br/>\n                <span className=\"text-stone-400\">Miss\303\243o e evangeliza\303\247\303\243o em Lisboa.</span>\n              </h2>\n\n              <p className=\"text-stone-600 text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                O verdadeiro poder n\303\243o se limita a c\303\263digo compilado ou resist\303\252ncias f\303\255sicas; reside na verdade partilhada. A minha jornada apoia-se firmemente na f\303\251 crist\303\243. \303\211 comum encontrar-me nas ruas hist\303\263ricas de Lisboa a partilhar o Evangelho e a dialogar abertamente com pessoas de todos os quadrantes socioculturais. Adicionalmente, dedico tempo ao ensino pr\303\241tico de portugu\303\252s para imigrantes e estrangeiros, auxiliando-os no processo de integra\303\247\303\243o cultural.\n              </p>\n\n              <div className=\"mt-8 bg-stone-50 border border-stone-100 rounded-xl p-4 flex flex-col gap-3 w-full\">\n                <span className=\"text-[10px] font-mono text-stone-400 uppercase tracking-widest\">Atividades Locais Cont\303\255nuas</span>\n                <div className=\"flex justify-between items-center text-xs text-stone-800 pb-2 border-b border-stone-100 font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Sparkles className=\"w-3.5 h-3.5 text-sky-600\" /> Evangelismo de Rua</span>\n                  <span className=\"text-stone-500\">Baixa-Chiado & Rossio</span>\n                </div>\n                <div className=\"flex justify-between items-center text-xs text-stone-800 font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Users className=\"w-3.5 h-3.5 text-sky-600\" /> Apoio de L\303\255ngua Portuguesa</span>\n                  <span className=\"text-stone-500\">Integra\303\247\303\243o Cultural</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 4: The Discipline (Fitness & Mindset) */}\n            <section\n              id=\"discipline\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-red-500/20 text-red-600 rounded-full\">\n                  A DISCIPLINA\n                </span>\n                <span className=\"text-[10px] font-mono text-stone-400\">CAP\303\215TULO 04</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-stone-900 tracking-wide leading-tight\">\n                For\303\247a no Ferro.<br/>\n                <span className=\"text-stone-400\">Superando a fasquia de 140kg no supino.</span>\n              </h2>\n\n              <p className=\"text-stone-600 text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                A mente projeta conceitos brilhantes, mas o corpo precisa de energia e perseveran\303\247a para execut\303\241-los sob extrema tens\303\243o. O treino f\303\255sico de for\303\247a \303\251 o meu crisol de disciplina di\303\241ria. Levantar 140kg no supino \303\251 mais do que uma m\303\251trica mec\303\242nica \342\200\224 \303\251 a prova emp\303\255rica de que a paci\303\252ncia, consist\303\252ncia e esfor\303\247o intencional moldam o foco. Esta tenacidade reflete-se diretamente nos meus estudos e na qualidade do meu c\303\263digo.\n              </p>\n\n              <div className=\"mt-8 flex gap-6 items-center flex-wrap\">\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-stone-400 uppercase\">Recorde Pessoal de Supino</span>\n                  <span className=\"font-display text-5xl text-red-600 leading-none mt-1\">140<sup className=\"text-xl\">KG</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-400 uppercase mt-1\">A\303\247o s\303\263lido e controlo</span>\n                </div>\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-stone-400 uppercase\">Consist\303\252ncia de H\303\241bitos</span>\n                  <span className=\"font-display text-5xl text-stone-900 leading-none mt-1\">100<sup className=\"text-xl\">%</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-400 uppercase mt-1\">Foco Di\303\241rio Sem Atalhos</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 5: The Invitation (CTA / Form Link) */}\n            <section\n              id=\"invitation\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pb-20 scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-amber-500/20 text-amber-600 rounded-full\">\n                  O CONVITE\n                </span>\n                <span className=\"text-[10px] font-mono text-stone-400\">CAP\303\215TULO 05</span>\n              </div>\n\n              <h2 className=\"font-display text-5xl sm:text-7xl text-stone-900 tracking-normal leading-[0.95] max-w-xl\">\n                Vamos Construir Algo Excecional.\n              </h2>\n\n              <p className=\"text-stone-600 text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                Se te sentes inspirado por este portf\303\263lio digital e procuras estruturar um espa\303\247o de marca premium para as tuas pr\303\263prias ideias, ou pretendes dialogar sobre engenharia, f\303\251 e prepara\303\247\303\243o f\303\255sica: a minha caixa de correio est\303\241 sempre de portas abertas.\n              </p>\n\n              <div className=\"flex flex-col sm:flex-row gap-4 mt-10 w-full max-w-md\">\n                <button\n                  id=\"invitation-contact-btn\"\n                  onClick={() => setIsContactOpen(true)}\n                  className=\"px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest bg-stone-950 text-white hover:bg-stone-800 transition-all flex items-center justify-center gap-1.5 cursor-pointer border-none animate-pulse\"\n                >\n                  Iniciar Conversa\n                </button>\n                <a\n                  id=\"invitation-ig-btn\"\n                  href=\"https://www.instagram.com/joao.brito_\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"liquid-glass px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest text-stone-800 hover:scale-[1.02] transition-transform flex items-center justify-center gap-2 border-none\"\n                >\n                  Mensagem Direta (Instagram)\n                </a>\n              </div>\n            </section>\n\n          </div>\n\n          {/* Right Hemisphere: Persistent high-end visual column */}\n          <div className=\"col-span-12 lg:col-span-5 h-[400px] lg:h-screen lg:sticky lg:top-0 flex flex-col justify-center items-center pointer-events-auto\">\n            {/* 3D Interactive Model Canvas container */}\n            <div className=\"w-full h-[320px] lg:h-[60%] flex items-center justify-center relative\">\n              <InteractiveModel activeSection={activeSection} />\n            </div>\n            \n            {/* Scroll Indicator helper text */}\n            <div className=\"mt-4 font-mono text-[10px] text-stone-400 uppercase tracking-[0.2em] hidden lg:block select-none animate-pulse\">\n              [ MOVIMENTA PARA ALTERAR A MATRIZ VETORIAL ]\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Slideout Modals Layer */}\n      <ContactModal\n        isOpen={isContactOpen}\n        onClose={() => setIsContactOpen(false)}\n      />\n      <ProjectHub\n        isOpen={isHubOpen}\n        onClose={() => setIsHubOpen(false)}\n        onContactClick={() => setIsContactOpen(true)}\n      />"
    }
