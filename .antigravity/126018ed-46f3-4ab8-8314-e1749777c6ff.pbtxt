    replacement_chunks {
      target_content: "@import url(\'https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", sans-serif;\n  --font-display: \"Instrument Serif\", serif;\n\n  --color-background: hsl(201 100% 13%);\n  --color-foreground: hsl(0 0% 100%);\n  --color-muted-foreground: hsl(240 4% 66%);\n  --color-primary: hsl(0 0% 100%);\n  --color-primary-foreground: hsl(0 0% 4%);\n  --color-secondary: hsl(0 0% 10%);\n  --color-muted: hsl(0 0% 10%);\n  --color-accent: hsl(0 0% 10%);\n  --color-border: hsl(0 0% 18%);\n  --color-input: hsl(0 0% 18%);\n}\n\n.liquid-glass {\n  background: rgba(255, 255, 255, 0.01);\n  background-blend-mode: luminosity;\n  backdrop-filter: blur(4px);\n  -webkit-backdrop-filter: blur(4px);\n  border: none;\n  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1);\n  position: relative;\n  overflow: hidden;\n}\n\n.liquid-glass::before {\n  content: \'\';\n  position: absolute;\n  inset: 0;\n  border-radius: inherit;\n  padding: 1.4px;\n  background: linear-gradient(\n    180deg,\n    rgba(255,255,255,0.45) 0%,\n    rgba(255,255,255,0.15) 20%,\n    rgba(255,255,255,0) 40%,\n    rgba(255,255,255,0) 60%,\n    rgba(255,255,255,0.15) 80%,\n    rgba(255,255,255,0.45) 100-percent\n  );\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n  -webkit-mask-composite: xor;\n  mask-composite: exclude;\n  pointer-events: none;\n}\n\n.display-text {\n  font-family: var(--font-display);\n  font-weight: 400;\n}\n\n.sphere-glow {\n  width: 400px;\n  height: 400px;\n  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);\n  border-radius: 50%;\n  filter: blur(40px);\n  position: absolute;\n  right: 10%;\n  top: 50%;\n  transform: translateY(-50%);\n  pointer-events: none;\n}\n\n@keyframes fade-rise {\n  from { opacity: 0; transform: translateY(24px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n.animate-fade-rise          { animation: fade-rise 0.8s ease-out 0s    both; }\n.animate-fade-rise-delay    { animation: fade-rise 0.8s ease-out 0.2s  both; }\n.animate-fade-rise-delay-2  { animation: fade-rise 0.8s ease-out 0.4s  both; }\n\n/* Custom scrollbar for a seamless dark luxury look */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: hsl(201 100% 13%);\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 9999px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Custom smooth scrolling */\nhtml {\n  scroll-behavior: smooth;\n}"
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", sans-serif;\n  --font-display: \"Instrument Serif\", serif;\n\n  --color-background: #ffffff;\n  --color-foreground: #111111;\n  --color-muted-foreground: #666666;\n  --color-primary: #111111;\n  --color-primary-foreground: #ffffff;\n  --color-secondary: #f4f4f5;\n  --color-muted: #f4f4f5;\n  --color-accent: #f4f4f5;\n  --color-border: #e4e4e7;\n  --color-input: #e4e4e7;\n}\n\n.liquid-glass {\n  background: rgba(0, 0, 0, 0.03);\n  background-blend-mode: luminosity;\n  backdrop-filter: blur(10px);\n  -webkit-backdrop-filter: blur(10px);\n  border: 1px solid rgba(0, 0, 0, 0.06);\n  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.8), 0 4px 20px rgba(0, 0, 0, 0.02);\n  position: relative;\n  overflow: hidden;\n}\n\n.liquid-glass::before {\n  content: \'\';\n  position: absolute;\n  inset: 0;\n  border-radius: inherit;\n  padding: 1px;\n  background: linear-gradient(\n    180deg,\n    rgba(0,0,0,0.15) 0%,\n    rgba(0,0,0,0.05) 20%,\n    rgba(0,0,0,0) 40%,\n    rgba(0,0,0,0) 60%,\n    rgba(0,0,0,0.05) 80%,\n    rgba(0,0,0,0.15) 100%\n  );\n  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n  -webkit-mask-composite: xor;\n  mask-composite: exclude;\n  pointer-events: none;\n}\n\n.display-text {\n  font-family: var(--font-display);\n  font-weight: 400;\n}\n\n.sphere-glow {\n  width: 500px;\n  height: 500px;\n  background: radial-gradient(circle, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0) 70%);\n  border-radius: 50%;\n  filter: blur(60px);\n  position: absolute;\n  right: 5%;\n  top: 50%;\n  transform: translateY(-50%);\n  pointer-events: none;\n}\n\n@keyframes fade-rise {\n  from { opacity: 0; transform: translateY(24px); }\n  to   { opacity: 1; transform: translateY(0); }\n}\n\n.animate-fade-rise          { animation: fade-rise 0.8s ease-out 0s    both; }\n.animate-fade-rise-delay    { animation: fade-rise 0.8s ease-out 0.2s  both; }\n.animate-fade-rise-delay-2  { animation: fade-rise 0.8s ease-out 0.4s  both; }\n\n/* Custom scrollbar for a seamless light luxury look */\n::-webkit-scrollbar {\n  width: 6px;\n}\n::-webkit-scrollbar-track {\n  background: #ffffff;\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(0, 0, 0, 0.1);\n  border-radius: 9999px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(0, 0, 0, 0.2);\n}\n\n/* Custom smooth scrolling */\nhtml {\n  scroll-behavior: smooth;\n}"
    }
    instruction: "Transition to clean white background luxury theme with high-contrast text and subtle neutral details."
  }
