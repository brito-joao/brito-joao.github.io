        }
        lines {
          text: "                <span className=\"text-[10px] font-mono text-stone-400 uppercase tracking-widest\">Atividades Locais Cont\303\255nuas</span>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
