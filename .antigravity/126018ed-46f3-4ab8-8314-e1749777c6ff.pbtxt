  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect, useRef } from \"react\";\nimport { SECTIONS } from \"./types\";\nimport InteractiveModel from \"./components/InteractiveModel\";\nimport FarLeftSpine from \"./components/FarLeftSpine\";\nimport RightSpine from \"./components/RightSpine\";\nimport InteractiveWidget from \"./components/InteractiveWidget\";\nimport ContactModal from \"./components/ContactModal\";\nimport ProjectHub from \"./components/ProjectHub\";\nimport { ArrowRight, ChevronRight, Check, Sparkles, Code2, Users, Flame, Heart, Cpu } from \"lucide-react\";\n\nexport default function App() {\n  const [activeSection, setActiveSection] = useState(\"hero\");\n  const [isContactOpen, setIsContactOpen] = useState(false);\n  const [isHubOpen, setIsHubOpen] = useState(false);\n  \n  // Ref to trigger canvas explosion key\n  const [pulseTrigger, setPulseTrigger] = useState(0);\n\n  // Set up intersection observer to detect active section dynamically on scroll\n  useEffect(() => {\n    const observers = SECTIONS.map((sec) => {\n      const el = document.getElementById(sec.id);\n      if (!el) return null;\n\n      const observer = new IntersectionObserver(\n        ([entry]) => {\n          if (entry.isIntersecting) {\n            setActiveSection(sec.id);\n          }\n        },\n        {\n          root: null,\n          rootMargin: \"-45% 0px -45% 0px\", // Trigger when section occupies the vertical center zone\n          threshold: 0\n        }\n      );\n\n      observer.observe(el);\n      return { observer, el };\n    });\n\n    return () => {\n      observers.forEach((obs) => {\n        if (obs) {\n          obs.observer.unobserve(obs.el);\n        }\n      });\n    };\n  }, []);\n\n  const triggerAnimationPulse = () => {\n    setPulseTrigger((prev) => prev + 1);\n  };\n\n  const handleScrollTo = (id: string) => {\n    const el = document.getElementById(id);\n    if (el) {\n      el.scrollIntoView({ behavior: \"smooth\" });\n    }\n  };\n\n  return (\n    <div className=\"relative min-h-screen bg-[#07161e] font-sans text-white overflow-x-hidden selection:bg-white selection:text-[#07161e]\">\n      \n      {/* Background Video Layer */}\n      <video\n        autoPlay\n        loop\n        muted\n        playsInline\n        className=\"fixed inset-0 w-full h-full object-cover z-0 opacity-40 pointer-events-none select-none\"\n        src=\"https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260314_131748_f2ca2a28-fed7-44c8-b9a9-bd9acdd5ec31.mp4\"\n      />\n\n      {/* Floating Elements / Spines Layer */}\n      <FarLeftSpine\n        onContactClick={() => setIsContactOpen(true)}\n        onMenuClick={() => setIsHubOpen(true)}\n      />\n      <RightSpine activeSection={activeSection} />\n\n      {/* Header element as requested by the brief */}\n      <header className=\"relative z-30 w-full max-w-7xl mx-auto px-8 py-6 flex justify-between items-center selection:bg-white selection:text-black\">\n        {/* Brand Logo */}\n        <div className=\"flex items-center gap-1\">\n          <span className=\"font-display text-3xl tracking-tight text-white cursor-pointer select-none\" onClick={() => handleScrollTo(\"hero\")}>\n            Velorah<sup className=\"text-xs ml-0.5 opacity-60\">\302\256</sup>\n          </span>\n          <div className=\"w-1.5 h-1.5 bg-sky-400 rounded-full animate-pulse ml-1.5 hidden sm:block\" />\n        </div>\n\n        {/* Navigation Menu Links */}\n        <nav className=\"hidden md:flex items-center gap-8 font-mono text-[11px] uppercase tracking-widest text-muted-foreground select-none\">\n          <button\n            id=\"nav-link-home\"\n            onClick={() => handleScrollTo(\"hero\")}\n            className={`transition-colors hover:text-white cursor-pointer ${activeSection === \"hero\" ? \"text-white font-bold\" : \"text-[#9ca3af]/60\"}`}\n          >\n            Home\n          </button>\n          <button\n            id=\"nav-link-studio\"\n            onClick={() => handleScrollTo(\"builder\")}\n            className={`transition-colors hover:text-white cursor-pointer ${activeSection === \"builder\" ? \"text-white font-bold\" : \"text-[#9ca3af]/60\"}`}\n          >\n            Studio\n          </button>\n          <button\n            id=\"nav-link-about\"\n            onClick={() => handleScrollTo(\"foundation\")}\n            className={`transition-colors hover:text-white cursor-pointer ${activeSection === \"foundation\" ? \"text-white font-bold\" : \"text-[#9ca3af]/60\"}`}\n          >\n            About\n          </button>\n          <button\n            id=\"nav-link-journal\"\n            onClick={() => handleScrollTo(\"discipline\")}\n            className={`transition-colors hover:text-white cursor-pointer ${activeSection === \"discipline\" ? \"text-white font-bold\" : \"text-[#9ca3af]/60\"}`}\n          >\n            Journal\n          </button>\n          <button\n            id=\"nav-link-reach\"\n            onClick={() => handleScrollTo(\"invitation\")}\n            className={`transition-colors hover:text-white cursor-pointer ${activeSection === \"invitation\" ? \"text-white font-bold\" : \"text-[#9ca3af]/60\"}`}\n          >\n            Reach Us\n          </button>\n        </nav>\n\n        {/* Nav CTA */}\n        <button\n          id=\"nav-cta-btn\"\n          onClick={() => setIsContactOpen(true)}\n          className=\"liquid-glass rounded-full px-6 py-2.5 text-xs uppercase tracking-widest font-mono text-white hover:scale-[1.03] transition-transform cursor-pointer border-none\"\n        >\n          Begin Journey\n        </button>\n      </header>\n\n      {/* Main Grid Content */}\n      <main className=\"relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12 selection:bg-white selection:text-black\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start min-h-screen\">\n          \n          {/* Left Hemisphere: Story scrolling column */}\n          <div className=\"col-span-12 lg:col-span-7 flex flex-col gap-24 pt-16 pr-0 lg:pr-8 pl-14 md:pl-20 pb-20\">\n            \n            {/* Section 1: Hero chapter */}\n            <section\n              id=\"hero\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pt-12 md:pt-20 scroll-mt-24\"\n            >\n              <span className=\"font-mono text-[10px] uppercase tracking-[0.3em] text-sky-400 font-bold mb-4 animate-fade-rise\">\n                CHAPTER I &mdash; VELORAH PRESENTS\n              </span>\n              \n              <h1 className=\"font-display text-5xl sm:text-7xl md:text-8xl leading-[0.95] tracking-[-2.46px] max-w-2xl font-normal text-white animate-fade-rise\">\n                Jo\303\243o Brito.<br/>\n                <em className=\"not-italic text-stone-500\">Where dreams rise through the silence.</em>\n              </h1>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base max-w-lg mt-8 leading-relaxed font-sans animate-fade-rise-delay\">\n                We&apos;re designing tools for deep thinkers, bold creators, and quiet rebels. \n                Amid the chaos of Lisboa, we build elegant, high-capacity digital architectures aligned with absolute faith and unwavering grit.\n              </p>\n\n              <div className=\"flex flex-wrap items-center gap-4 mt-12 animate-fade-rise-delay-2 w-full\">\n                <button\n                  id=\"hero-cta-begin\"\n                  onClick={() => handleScrollTo(\"builder\")}\n                  className=\"liquid-glass rounded-full px-10 py-4 text-xs uppercase tracking-widest font-mono text-white hover:scale-[1.03] transition-transform flex items-center gap-2 cursor-pointer border-none\"\n                >\n                  Explore My Work <ArrowRight className=\"w-3.5 h-3.5 text-sky-400\" />\n                </button>\n                <button\n                  id=\"hero-sub-btn\"\n                  onClick={() => setIsHubOpen(true)}\n                  className=\"px-6 py-4 text-xs font-mono tracking-widest text-white/50 hover:text-white transition-colors uppercase\"\n                >\n                  Brief Technical Index\n                </button>\n              </div>\n            </section>\n\n            {/* Section 2: The Builder (Engineering & Tech) */}\n            <section\n              id=\"builder\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-emerald-500/20 text-emerald-400 rounded-full\">\n                  THE BUILDER\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">02. CHAPTER</span>\n              </div>\n              \n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Precision in Everything.<br/>\n                <span className=\"text-stone-500\">Deloitte analytical orchestration.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                I am a 21-year-old Electrical Engineering student in Portugal with an absolute obsession for how systems connect&mdash;from physical analog microcircuits to flawless, reactive digital interfaces. \n                Bringing two years of analytical corporate auditing with Deloitte into my coding backlog, I merge high-end strategy with robust technical discipline.\n              </p>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 mt-10 w-full\">\n                <div className=\"bg-white/1 border border-white/5 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-white font-medium mb-1.5 text-xs font-mono\">\n                    <Cpu className=\"w-3.5 h-3.5 text-emerald-400\" />\n                    ELECTRICAL ENGINEERING\n                  </div>\n                  <p className=\"text-[11px] text-muted-foreground leading-relaxed\">\n                    Academic research, transient circuits simulation, and hardware-software coupling models with structural safety.\n                  </p>\n                </div>\n\n                <div className=\"bg-white/1 border border-white/5 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-white font-medium mb-1.5 text-xs font-mono\">\n                    <Code2 className=\"w-3.5 h-3.5 text-emerald-400\" />\n                    DIGITAL ARCHITECTURE\n                  </div>\n                  <p className=\"text-[11px] text-muted-foreground leading-relaxed\">\n                    Developing modern Interactive frontends with custom canvas algorithms, high-capacity APIs, and React architectures.\n                  </p>\n                </div>\n              </div>\n\n              <button\n                id=\"builder-hub-btn\"\n                onClick={() => setIsHubOpen(true)}\n                className=\"mt-8 text-xs font-mono font-bold tracking-widest text-emerald-400 hover:text-white uppercase flex items-center gap-1 transition-colors cursor-pointer\"\n              >\n                OPEN ACADEMIC PROJECT MATRIX <ChevronRight className=\"w-3.5 h-3.5\" />\n              </button>\n            </section>\n\n            {/* Section 3: The Foundation (Faith & Community) */}\n            <section\n              id=\"foundation\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-sky-400/20 text-sky-400 rounded-full\">\n                  THE FOUNDATION\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">03. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Driven by Purpose.<br/>\n                <span className=\"text-stone-500\">Street preaching across Lisbon.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                True power is not merely compiled in code or physical resistors; it is shared through the truth. \n                My entire philosophy is deeply rooted in absolute faith. You can find me regularly on the streets of Lisboa, sharing the Gospel and connecting with thinkers from all cultures. \n                In addition to ministry, I dedicate regular intervals to teaching Portuguese to foreign seekers, helping them lay roots in our country.\n              </p>\n\n              <div className=\"mt-8 bg-white/1 border border-white/5 rounded-xl p-4 flex flex-col gap-3 w-full\">\n                <span className=\"text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">Ongoing Lisbon Assignments</span>\n                <div className=\"flex justify-between items-center text-xs text-white pb-2 border-b border-white/5 font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Sparkles className=\"w-3.5 h-3.5 text-sky-400\" /> Street Ministry Preach</span>\n                  <span className=\"text-muted-foreground\">Baixa-Chiado & Rossio</span>\n                </div>\n                <div className=\"flex justify-between items-center text-xs text-white font-mono\">\n                  <span className=\"flex items-center gap-1.5\"><Users className=\"w-3.5 h-3.5 text-sky-400\" /> Portuguese Instruction</span>\n                  <span className=\"text-muted-foreground\">Conversational Integration</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 4: The Discipline (Fitness & Mindset) */}\n            <section\n              id=\"discipline\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-red-500/20 text-red-400 rounded-full\">\n                  THE DISCIPLINE\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">04. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Discipline in the Iron.<br/>\n                <span className=\"text-stone-500\">Crushing the 140kg bench press limit.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                The mind designs beautiful conceptual paradigms, but the body must possess the grit to execute them under immense stress. \n                Physical training represents my absolute daily crucible. Bench-pressing 140kg isn&apos;t just a mechanical statistic&mdash;it stands as raw evidence that consistency, patience, and unwavering intensity yield undeniable performance. \n                This exact tenacity translates seamlessly into my engineering studies and code refinement.\n              </p>\n\n              <div className=\"mt-8 flex gap-6 items-center flex-wrap\">\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-muted-foreground uppercase\">Bench Press Personal Best</span>\n                  <span className=\"font-display text-5xl text-red-400 leading-none mt-1\">140<sup className=\"text-xl\">KG</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-500 uppercase mt-1\">308 Pounds Solid Steel</span>\n                </div>\n                <div className=\"flex flex-col text-left\">\n                  <span className=\"text-[9px] font-mono text-muted-foreground uppercase\">Daily Grind Consistency</span>\n                  <span className=\"font-display text-5xl text-white leading-none mt-1\">100<sup className=\"text-xl\">%</sup></span>\n                  <span className=\"text-[10px] font-mono text-stone-500 uppercase mt-1\">Zero Days Skipped / Absolute Focus</span>\n                </div>\n              </div>\n            </section>\n\n            {/* Section 5: The Invitation (CTA / Form Link) */}\n            <section\n              id=\"invitation\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pb-20 scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-amber-500/20 text-amber-500 rounded-full\">\n                  THE INVITATION\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">05. CHAPTER</span>\n              </div>\n\n              <h2 className=\"font-display text-5xl sm:text-7xl text-white tracking-normal leading-[0.95] max-w-xl\">\n                Let&apos;s Build Something Exceptional.\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                If you are inspired by this custom interactive portfolio and desire an elite, premium digital brand space that captures your unique story, or if you simply are eager to connect over engineering, faith, or strength training: my inbox is permanently configured to receive you.\n              </p>\n\n              <div className=\"flex flex-col sm:flex-row gap-4 mt-10 w-full max-w-md\">\n                <button\n                  id=\"invitation-contact-btn\"\n                  onClick={() => setIsContactOpen(true)}\n                  className=\"px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest bg-white text-black hover:bg-stone-200 transition-all flex items-center justify-center gap-1.5 cursor-pointer border-none\"\n                >\n                  Start a Conversation\n                </button>\n                <a\n                  id=\"invitation-ig-btn\"\n                  href=\"https://www.instagram.com/joao.brito_\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"liquid-glass px-8 py-4 rounded-full text-xs font-mono font-bold uppercase tracking-widest text-white hover:scale-[1.02] transition-transform flex items-center justify-center gap-2 border-none\"\n                >\n                  Direct Instagram DM\n                </a>\n              </div>\n            </section>\n\n          </div>\n\n          {/* Right Hemisphere: Persistent high-end visual column */}\n          <div className=\"col-span-12 lg:col-span-5 h-[400px] lg:h-screen lg:sticky lg:top-0 flex flex-col justify-center items-center pointer-events-auto\">\n            {/* 3D Interactive Model Canvas container */}\n            <div className=\"w-full h-[320px] lg:h-[60%] flex items-center justify-center relative\">\n              <InteractiveModel activeSection={activeSection} />\n            </div>\n            \n            {/* Scroll Indicator helper text */}\n            <div className=\"mt-4 font-mono text-[10px] text-muted-foreground/30 uppercase tracking-[0.2em] hidden lg:block select-none animate-pulse\">\n              [ SCROLL TO MORPH VECTOR MATRIX ]\n            </div>\n          </div>\n\n        </div>\n      </main>\n\n      {/* Pinned Bottom-Left Zone: Dedicated Interactive Widget placement */}\n      <div className=\"fixed bottom-6 left-6 md:left-24 z-30 max-w-[340px] pointer-events-auto hidden md:block select-none hover:translate-y-[-4px] transition-all duration-300\">\n        <InteractiveWidget onTriggerPulse={triggerAnimationPulse} />\n      </div>\n\n      {/* Mobile-only collapsed Bottom Widget (Collapsible for spacing) */}\n      <div className=\"w-full px-6 py-6 border-t border-white/5 bg-[#07161e]/80 backdrop-blur-xl md:hidden relative z-30 selection:bg-white selection:text-black mt-10\">\n        <span className=\"text-[10px] font-mono text-stone-500 uppercase tracking-widest mb-2 block\">Interactive Ambient Center</span>\n        <InteractiveWidget onTriggerPulse={triggerAnimationPulse} />\n      </div>\n\n      {/* Slideout Modals Layer */}\n      <ContactModal\n        isOpen={isContactOpen}\n        onClose={() => setIsContactOpen(false)}\n      />\n      <ProjectHub\n        isOpen={isHubOpen}\n        onClose={() => setIsHubOpen(false)}\n        onContactClick={() => setIsContactOpen(true)}\n      />\n\n    </div>\n  );\n}\n"
    }
