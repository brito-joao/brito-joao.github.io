aining, 140kg bench press & focus\" },\n];\n\nexport const PROJECTS: Project[] = [\n  {\n    title: \"Deloitte Corporate Orchestration\",\n    category: \"Corporate Consulting\",\n    description: \"Supported large-scale digital audits, analyzing system architectures, and aligning codebases for high-performing enterprise apps.\",\n    tech: [\"Systems Audit\", \"Architecture\", \"Consulting\"],\n    metrics: \"2 Years Experience\"\n  },\n  {\n    title: \"Gospel Outreach Lisbon\",\n    category: \"Community & Faith\",\n    description: \"Orchestrating public discussion, teaching and guiding street ministries across the historic neighborhoods of Lisbon, Portugal.\",\n    tech: [\"Outreach\", \"Leadership\", \"Teaching\"],\n    metrics: \"Lisbon, Portugal\"\n  },\n  {\n    title: \"Circuit Analytics Suite\",\n    category: \"Electrical Engineering\",\n    description: \"An interactive educational modeling software for simulating transient responses in RLC circuits and signal propagation.\",\n    tech: [\"RLC Simulation\", \"Signal Processing\", \"Fourier\"],\n    metrics: \"98% Efficiency\"\n  }\n];\n\nexport const CHURCH_TIMELINE: ChurchTimelineEvent[] = [\n  {\n    year: \"Ongoing\",\n    title: \"Lisbon Street Preaching\",\n    description: \"Sharing the Gospel openly in public squares, engaging in deep conversations about meaning and absolute truth.\",\n    location: \"Baixa-Chiado & Rossio\"\n  },\n  {\n    year: \"Weekly\",\n    title: \"Youth Group & Community Integration\",\n    description: \"Leading local church discussions for younger demographics, helping bridge faith with everyday engineering studies.\",\n    location: \"Lisbon, Portugal\"\n  },\n  {\n    year: \"Academic\",\n    title: \"Portuguese Language Exchange\",\n    description: \"Teaching conversational Portuguese to expats and international students, helping them integrate into Portugal\'s vibrant culture.\",\n    location: \"Lisbon University\"\n  }\n];\n"
