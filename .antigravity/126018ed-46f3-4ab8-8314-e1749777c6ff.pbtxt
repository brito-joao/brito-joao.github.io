        target_content: "              <div className=\"flex flex-wrap items-center gap-4 mt-12 animate-fade-rise-delay-2 w-full\">\n                <button\n                  id=\"hero-cta-begin\"\n                  onClick={() => handleScrollTo(\"builder\")}\n                  className=\"liquid-glass rounded-full px-10 py-4 text-xs uppercase tracking-widest font-mono text-stone-900 hover:scale-[1.03] transition-transform flex items-center gap-2 cursor-pointer border-none\"\n                >\n                  Explorar o Meu Trabalho <ArrowRight className=\"w-3.5 h-3.5 text-emerald-600\" />\n                </button>\n                <button\n                  id=\"hero-sub-btn\"\n                  onClick={() => setIsHubOpen(true)}\n                  className=\"px-6 py-4 text-xs font-mono tracking-widest text-stone-500 hover:text-stone-900 transition-colors uppercase\"\n                >\n                  \303\215ndice T\303\251cnico de Projetos\n                </button>\n              </div>\n            </section>"
        replacement_content: "              <div className=\"flex flex-wrap items-center gap-4 mt-12 animate-fade-rise-delay-2 w-full\">\n                <button\n                  id=\"hero-cta-begin\"\n                  onClick={() => handleScrollTo(\"builder\")}\n                  className=\"liquid-glass rounded-full px-10 py-4 text-xs uppercase tracking-widest font-mono text-stone-900 hover:scale-[1.03] transition-transform flex items-center gap-2 cursor-pointer border-none\"\n                >\n                  Explorar o Meu Trabalho <ArrowRight className=\"w-3.5 h-3.5 text-emerald-600\" />\n                </button>\n                <button\n                  id=\"hero-sub-btn\"\n                  onClick={() => setIsHubOpen(true)}\n                  className=\"px-6 py-4 text-xs font-mono tracking-widest text-stone-500 hover:text-stone-900 transition-colors uppercase\"\n                >\n                  \303\215ndice T\303\251cnico de Projetos\n                </button>\n              </div>\n\n              {/* Scroll-scrubbed Hero Video frame of Jo\303\243o */}\n              <div className=\"w-full mt-10 max-w-xl group relative overflow-hidden rounded-2xl border border-stone-200 bg-stone-50 shadow-md aspect-[16/10] select-none animate-fade-rise-delay-2\">\n                {/* Decorative retro coordinate interface grid */}\n                <div className=\"absolute top-3 left-4 z-20 flex items-center gap-2\">\n                  <span className=\"w-2 h-2 rounded-full bg-emerald-500 animate-pulse\" />\n                  <span className=\"text-[9px] font-mono font-bold tracking-wider text-stone-700 bg-white/90 backdrop-blur-md px-2.5 py-1 rounded border border-stone-200 uppercase\">\n                    REGISTO ATIVO &mdash; JO\303\203O BRITO\n                  </span>\n                </div>\n                \n                <span className=\"absolute top-3 right-4 z-20 text-[9px] font-mono font-medium text-stone-500 bg-white/90 backdrop-blur-md px-2.5 py-1 rounded border border-stone-200\">\n                  DESLIZE PARA NAVEGAR\n                </span>\n\n                <video\n                  ref={videoRef}\n                  preload=\"auto\"\n                  muted\n                  playsInline\n                  className=\"w-full h-full object-cover relative z-10 block pointer-events-none filter brightness-95 rounded-2xl\"\n                  src=\"https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260314_131748_f2ca2a28-fed7-44c8-b9a9-bd9acdd5ec31.mp4\"\n                />\n\n                {/* Subtitle / Overlay metrics tray at the bottom */}\n                <div className=\"absolute bottom-0 inset-x-0 z-20 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-4 flex flex-col gap-2 pt-12 text-white\">\n                  <div className=\"flex justify-between items-center z-30\">\n                    <span className=\"text-[10px] font-mono font-semibold tracking-wider text-emerald-400\">INDEXA\303\207\303\203O DE FITA (FRAME)</span>\n                    <span className=\"text-[10px] font-mono text-stone-200 font-bold\">{Math.round(currentProgressPct)}%</span>\n                  </div>\n                  \n                  {/* Dynamic scrub visual tracker bar */}\n                  <div className=\"w-full h-1 bg-white/20 rounded-full overflow-hidden z-30\">\n                    <div \n                      className=\"bg-emerald-400 h-full transition-all duration-75\"\n                      style={{ width: `${currentProgressPct}%` }}\n                    />\n                  </div>\n                </div>\n              </div>\n            </section>"
      }
      num_matches: 1
    }
  }
