          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                Precis\303\243o em Tudo.<br/>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <span className=\"text-stone-400\">Orquestra\303\247\303\243o anal\303\255tica na Deloitte.</span>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
