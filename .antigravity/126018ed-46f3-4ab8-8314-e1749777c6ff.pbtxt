  file_change {
    absolute_path_uri: "file:///src/components/ProjectHub.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { X, ExternalLink, Code, Layers, MessageSquare, Flame, CheckCircle, BrainCircuit } from \"lucide-react\";\nimport { PROJECTS, CHURCH_TIMELINE, TECH_SKILLS } from \"../types\";\n\ninterface ProjectHubProps {\n  isOpen: boolean;\n  onClose: () => void;\n  onContactClick: () => void;\n}\n\nexport default function ProjectHub({ isOpen, onClose, onContactClick }: ProjectHubProps) {\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 bg-background/95 backdrop-blur-2xl z-50 flex justify-end selection:bg-white select-none\">\n      {/* Sliding sidebar block */}\n      <div className=\"w-full max-w-2xl bg-[#0a1c24]/90 border-l border-white/10 h-full overflow-y-auto flex flex-col p-6 md:p-10 text-left animate-fade-rise duration-300\">\n        \n        {/* Header toolbar */}\n        <div className=\"flex justify-between items-center border-b border-white/5 pb-6 mb-8\">\n          <div>\n            <span className=\"font-mono text-[10px] text-[#34d399] tracking-widest uppercase\">CRITICAL SYSTEM DIRECTORY</span>\n            <h2 className=\"font-display text-4xl text-white tracking-wide mt-1\">Architecture & Missions</h2>\n          </div>\n          <button\n            id=\"hub-close-btn\"\n            onClick={onClose}\n            className=\"w-10 h-10 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center text-muted-foreground hover:text-white transition-all cursor-pointer\"\n            title=\"Close hub\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n\n        {/* Technical Competencies Grid */}\n        <div className=\"mb-10\">\n          <span className=\"text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">CRUCIBLE COMPETENCY RADIAN</span>\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4\">\n            {TECH_SKILLS.map((skill) => (\n              <div key={skill.name} className=\"bg-white/2 border border-white/5 rounded-xl p-3 flex flex-col gap-2 relative overflow-hidden group hover:border-white/10 transition-colors\">\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-white text-xs font-semibold\">{skill.name}</span>\n                  <span className=\"text-[10px] font-mono text-emerald-400 font-bold\">{skill.level}%</span>\n                </div>\n                {/* Simulated capacity level bar */}\n                <div className=\"w-full bg-white/5 h-1 rounded-full overflow-hidden\">\n                  <div className=\"bg-emerald-400 h-full transition-all duration-1000\" style={{ width: `${skill.level}%` }} />\n                </div>\n                <p className=\"text-[10px] text-muted-foreground font-mono leading-relaxed\">{skill.detail}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Deloitte & Web Systems Grid */}\n        <div className=\"mb-10\">\n          <span className=\"text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">ENGINEERING & ENTERPRISE PORTFOLIO</span>\n          <div className=\"flex flex-col gap-4 mt-4\">\n            {PROJECTS.map((p) => (\n              <div key={p.title} className=\"bg-white/2 border border-white/5 rounded-xl p-4 flex flex-col gap-2 md:flex-row md:justify-between hover:border-white/10 transition-colors\">\n                <div className=\"flex-1 text-left\">\n                  <div className=\"flex items-center gap-2 mb-1\">\n                    <span className=\"text-white font-semibold text-sm font-sans\">{p.title}</span>\n                    <span className=\"text-[9px] font-mono text-sky-400 border border-sky-400/20 px-1.5 py-0.5 rounded uppercase\">{p.category}</span>\n                  </div>\n                  <p className=\"text-xs text-muted-foreground leading-relaxed font-sans\">{p.description}</p>\n                  \n                  {/* Technology Tags */}\n                  <div className=\"flex gap-2 flex-wrap mt-3\">\n                    {p.tech.map((t) => (\n                      <span key={t} className=\"text-[9px] font-mono text-stone-400 bg-white/5 px-2 py-0.5 rounded-full\">\n                        {t}\n                      </span>\n                    ))}\n                  </div>\n                </div>\n                <div className=\"flex items-end justify-between md:flex-col md:items-end md:justify-center border-t border-white/5 md:border-t-0 pt-3 md:pt-0 mt-3 md:mt-0\">\n                  <span className=\"text-[10px] font-mono text-stone-500 uppercase tracking-wider\">VALUE DELIVERED</span>\n                  <span className=\"text-xs text-white font-mono font-bold mt-1\">{p.metrics}</span>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Faith Ministry Timetable */}\n        <div className=\"mb-10\">\n          <span className=\"text-[10px] font-mono text-muted-foreground uppercase tracking-widest\">MINISTRY TIMELINE & FELLOWSHIP</span>\n          <div className=\"border-l border-white/10 ml-2 mt-4 pl-6 flex flex-col gap-6 text-left\">\n            {CHURCH_TIMELINE.map((evt) => (\n              <div key={evt.title} className=\"relative group\">\n                {/* Absolute chronological indicator dot */}\n                <div className=\"absolute -left-[31px] top-1 w-2.5 h-2.5 rounded-full bg-sky-400 border border-[#0a1c24] group-hover:bg-white transition-all\" />\n                <span className=\"text-[10px] font-mono text-sky-400 font-bold uppercase\">{evt.year} &mdash; {evt.location}</span>\n                <p className=\"text-sm font-semibold text-white mt-0.5\">{evt.title}</p>\n                <p className=\"text-xs text-muted-foreground mt-1 leading-relaxed font-sans\">{evt.description}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* CTA Banner inside footer hub */}\n        <div className=\"mt-auto pt-6 border-t border-white/5 bg-white/1 -mx-6 px-6 md:-mx-10 md:px-10 flex flex-col md:flex-row justify-between items-center gap-4\">\n          <div>\n            <p className=\"text-xs text-white font-bold font-sans\">Inspired to design collaborative digital architecture?</p>\n            <p className=\"text-[10px] text-muted-foreground font-mono\">My mailbox is open for corporate and pulpit assignments.</p>\n          </div>\n          <button\n            id=\"hub-contact-trigger-btn\"\n            onClick={() => {\n              onClose();\n              onContactClick();\n            }}\n            className=\"rounded-full px-5 py-2 text-xs font-mono font-bold uppercase tracking-widest bg-white text-black hover:bg-stone-200 transition-all cursor-pointer\"\n          >\n            LET\'S CONVERSE\n          </button>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n"
    }
