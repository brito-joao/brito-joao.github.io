    instruction: "Translate Hero and Builder chapters to Portuguese, remove Velorah references, change text-white to text-stone-900, and update visual utility borders for light mode."
    replacement_infos {
      original_chunk {
        target_content: "          {/* Left Hemisphere: Story scrolling column */}\n          <div className=\"col-span-12 lg:col-span-7 flex flex-col gap-24 pt-16 pr-0 lg:pr-8 pl-14 md:pl-20 pb-20\">\n            \n            {/* Section 1: Hero chapter */}\n            <section\n              id=\"hero\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pt-12 md:pt-20 scroll-mt-24\"\n            >\n              <span className=\"font-mono text-[10px] uppercase tracking-[0.3em] text-sky-400 font-bold mb-4 animate-fade-rise\">\n                CHAPTER I &mdash; VELORAH PRESENTS\n              </span>\n              \n              <h1 className=\"font-display text-5xl sm:text-7xl md:text-8xl leading-[0.95] tracking-[-2.46px] max-w-2xl font-normal text-white animate-fade-rise\">\n                Jo\303\243o Brito.<br/>\n                <em className=\"not-italic text-stone-500\">Where dreams rise through the silence.</em>\n              </h1>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base max-w-lg mt-8 leading-relaxed font-sans animate-fade-rise-delay\">\n                We&apos;re designing tools for deep thinkers, bold creators, and quiet rebels. \n                Amid the chaos of Lisboa, we build elegant, high-capacity digital architectures aligned with absolute faith and unwavering grit.\n              </p>\n\n              <div className=\"flex flex-wrap items-center gap-4 mt-12 animate-fade-rise-delay-2 w-full\">\n                <button\n                  id=\"hero-cta-begin\"\n                  onClick={() => handleScrollTo(\"builder\")}\n                  className=\"liquid-glass rounded-full px-10 py-4 text-xs uppercase tracking-widest font-mono text-white hover:scale-[1.03] transition-transform flex items-center gap-2 cursor-pointer border-none\"\n                >\n                  Explore My Work <ArrowRight className=\"w-3.5 h-3.5 text-sky-400\" />\n                </button>\n                <button\n                  id=\"hero-sub-btn\"\n                  onClick={() => setIsHubOpen(true)}\n                  className=\"px-6 py-4 text-xs font-mono tracking-widest text-white/50 hover:text-white transition-colors uppercase\"\n                >\n                  Brief Technical Index\n                </button>\n              </div>\n            </section>\n\n            {/* Section 2: The Builder (Engineering & Tech) */}\n            <section\n              id=\"builder\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-emerald-500/20 text-emerald-400 rounded-full\">\n                  THE BUILDER\n                </span>\n                <span className=\"text-[10px] font-mono text-muted-foreground\">02. CHAPTER</span>\n              </div>\n              \n              <h2 className=\"font-display text-4xl sm:text-6xl text-white tracking-wide leading-tight\">\n                Precision in Everything.<br/>\n                <span className=\"text-stone-500\">Deloitte analytical orchestration.</span>\n              </h2>\n\n              <p className=\"text-muted-foreground text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                I am a 21-year-old Electrical Engineering student in Portugal with an absolute obsession for how systems connect&mdash;from physical analog microcircuits to flawless, reactive digital interfaces. \n                Bringing two years of analytical corporate auditing with Deloitte into my coding backlog, I merge high-end strategy with robust technical discipline.\n              </p>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 mt-10 w-full\">\n                <div className=\"bg-white/1 border border-white/5 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-white font-medium mb-1.5 text-xs font-mono\">\n                    <Cpu className=\"w-3.5 h-3.5 text-emerald-400\" />\n                    ELECTRICAL ENGINEERING\n                  </div>\n                  <p className=\"text-[11px] text-muted-foreground leading-relaxed\">\n                    Academic research, transient circuits simulation, and hardware-software coupling models with structural safety.\n                  </p>\n                </div>\n\n                <div className=\"bg-white/1 border border-white/5 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-white font-medium mb-1.5 text-xs font-mono\">\n                    <Code2 className=\"w-3.5 h-3.5 text-emerald-400\" />\n                    DIGITAL ARCHITECTURE\n                  </div>\n                  <p className=\"text-[11px] text-muted-foreground leading-relaxed\">\n                    Developing modern Interactive frontends with custom canvas algorithms, high-capacity APIs, and React architectures.\n                  </p>\n                </div>\n              </div>\n\n              <button\n                id=\"builder-hub-btn\"\n                onClick={() => setIsHubOpen(true)}\n                className=\"mt-8 text-xs font-mono font-bold tracking-widest text-emerald-400 hover:text-white uppercase flex items-center gap-1 transition-colors cursor-pointer\"\n              >\n                OPEN ACADEMIC PROJECT MATRIX <ChevronRight className=\"w-3.5 h-3.5\" />\n              </button>\n            </section>"
        replacement_content: "          {/* Left Hemisphere: Story scrolling column */}\n          <div className=\"col-span-12 lg:col-span-7 flex flex-col gap-24 pt-16 pr-0 lg:pr-8 pl-14 md:pl-20 pb-20\">\n            \n            {/* Section 1: Hero chapter */}\n            <section\n              id=\"hero\"\n              className=\"min-h-[80vh] flex flex-col justify-center items-start text-left pt-12 md:pt-20 scroll-mt-24\"\n            >\n              <span className=\"font-mono text-[10px] uppercase tracking-[0.3em] text-emerald-600 font-bold mb-4 animate-fade-rise\">\n                CAP\303\215TULO I &mdash; APRESENTA\303\207\303\203O\n              </span>\n              \n              <h1 className=\"font-display text-5xl sm:text-7xl md:text-8xl leading-[0.95] tracking-[-2.46px] max-w-2xl font-normal text-stone-900 animate-fade-rise\">\n                Jo\303\243o Brito.<br/>\n                <em className=\"not-italic text-stone-400\">Onde os sonhos se erguem no sil\303\252ncio.</em>\n              </h1>\n\n              <p className=\"text-stone-600 text-sm sm:text-base max-w-lg mt-8 leading-relaxed font-sans animate-fade-rise-delay\">\n                Desenvolvo solu\303\247\303\265es digitais para pensadores audazes e mentes focadas. \n                No cora\303\247\303\243o de Lisboa, crio arquiteturas de software elegantes e de alta performance, impulsionado por uma f\303\251 s\303\263lida e uma disciplina inabal\303\241vel.\n              </p>\n\n              <div className=\"flex flex-wrap items-center gap-4 mt-12 animate-fade-rise-delay-2 w-full\">\n                <button\n                  id=\"hero-cta-begin\"\n                  onClick={() => handleScrollTo(\"builder\")}\n                  className=\"liquid-glass rounded-full px-10 py-4 text-xs uppercase tracking-widest font-mono text-stone-900 hover:scale-[1.03] transition-transform flex items-center gap-2 cursor-pointer border-none\"\n                >\n                  Explorar o Meu Trabalho <ArrowRight className=\"w-3.5 h-3.5 text-emerald-600\" />\n                </button>\n                <button\n                  id=\"hero-sub-btn\"\n                  onClick={() => setIsHubOpen(true)}\n                  className=\"px-6 py-4 text-xs font-mono tracking-widest text-stone-500 hover:text-stone-900 transition-colors uppercase\"\n                >\n                  \303\215ndice T\303\251cnico de Projetos\n                </button>\n              </div>\n            </section>\n\n            {/* Section 2: The Builder (Engineering & Tech) */}\n            <section\n              id=\"builder\"\n              className=\"min-h-[75vh] flex flex-col justify-center items-start text-left scroll-mt-24\"\n            >\n              <div className=\"flex items-center gap-2 mb-3\">\n                <span className=\"px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-widest border border-emerald-500/20 text-emerald-600 rounded-full\">\n                  O CONSTRUTOR\n                </span>\n                <span className=\"text-[10px] font-mono text-stone-400\">CAP\303\215TULO 02</span>\n              </div>\n              \n              <h2 className=\"font-display text-4xl sm:text-6xl text-stone-900 tracking-wide leading-tight\">\n                Precis\303\243o em Tudo.<br/>\n                <span className=\"text-stone-400\">Orquestra\303\247\303\243o anal\303\255tica na Deloitte.</span>\n              </h2>\n\n              <p className=\"text-stone-600 text-sm sm:text-base mt-6 leading-relaxed max-w-lg font-sans\">\n                Sou um estudante de Engenharia Eletrot\303\251cnica de 21 anos em Portugal, com uma obsess\303\243o pela forma como os sistemas se conectam &mdash; desde circuitos anal\303\263gicos integrados at\303\251 interfaces digitais fluidas e reativas. Fundo uma mentalidade profissional de consultoria e auditoria na Deloitte com um desenvolvimento meticuloso e rigoroso.\n              </p>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 mt-10 w-full\">\n                <div className=\"bg-stone-50 border border-stone-100 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-stone-900 font-semibold mb-1.5 text-xs font-mono\">\n                    <Cpu className=\"w-3.5 h-3.5 text-emerald-600\" />\n                    ENGENHARIA ELETROT\303\211CNICA\n                  </div>\n                  <p className=\"text-[11px] text-stone-500 leading-relaxed\">\n                    Investiga\303\247\303\243o acad\303\251mica, modela\303\247\303\243o e simula\303\247\303\243o de circuitos de corrente e an\303\241lise de transit\303\263rios com integridade f\303\255sica.\n                  </p>\n                </div>\n\n                <div className=\"bg-stone-50 border border-stone-100 p-4 rounded-xl hover:border-emerald-500/25 transition-colors\">\n                  <div className=\"flex items-center gap-1.5 text-stone-900 font-semibold mb-1.5 text-xs font-mono\">\n                    <Code2 className=\"w-3.5 h-3.5 text-emerald-600\" />\n                    ARQUITETURA DIGITAL\n                  </div>\n                  <p className=\"text-[11px] text-stone-500 leading-relaxed\">\n                    Desenvolvimento de interfaces modernas e algoritmos visuais que respondem com alto dinamismo recorrendo a React e APIs.\n                  </p>\n                </div>\n              </div>\n\n              <button\n                id=\"builder-hub-btn\"\n                onClick={() => setIsHubOpen(true)}\n                className=\"mt-8 text-xs font-mono font-bold tracking-widest text-emerald-600 hover:text-stone-900 uppercase flex items-center gap-1 transition-colors cursor-pointer\"\n              >\n                VER PORTF\303\223LIO E ACADEMIA <ChevronRight className=\"w-3.5 h-3.5\" />\n              </button>\n            </section>"
      }
      num_matches: 1
    }
  }
