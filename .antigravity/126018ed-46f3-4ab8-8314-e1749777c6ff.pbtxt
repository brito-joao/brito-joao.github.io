          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "              <h2 className=\"font-display text-4xl sm:text-6xl text-stone-900 tracking-wide leading-tight\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                Guiado por Prop\303\263sito.<br/>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                <span className=\"text-stone-400\">Miss\303\243o e evangeliza\303\247\303\243o em Lisboa.</span>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
