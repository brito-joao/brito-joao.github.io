        lines {
          text: "                  <div className=\"flex items-center gap-1.5 text-stone-900 font-semibold mb-1.5 text-xs font-mono\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <Cpu className=\"w-3.5 h-3.5 text-emerald-600\" />"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    ENGENHARIA ELETROT\303\211CNICA"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
