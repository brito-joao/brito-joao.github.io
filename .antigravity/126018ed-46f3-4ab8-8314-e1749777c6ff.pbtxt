  file_change {
    absolute_path_uri: "file:///src/components/ContactModal.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { X, Check, Instagram, Send, Mail } from \"lucide-react\";\n\ninterface ContactModalProps {\n  isOpen: boolean;\n  onClose: () => void;\n}\n\nexport default function ContactModal({ isOpen, onClose }: ContactModalProps) {\n  const [name, setName] = useState(\"\");\n  const [email, setEmail] = useState(\"\");\n  const [category, setCategory] = useState(\"Digital Client\");\n  const [message, setMessage] = useState(\"\");\n  const [submitted, setSubmitted] = useState(false);\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!name || !email || !message) return;\n    \n    // Simulate high-end analytics log submission\n    setSubmitted(true);\n    setTimeout(() => {\n      setName(\"\");\n      setEmail(\"\");\n      setMessage(\"\");\n      setSubmitted(false);\n      onClose();\n    }, 2800);\n  };\n\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 bg-background/80 backdrop-blur-xl z-50 flex items-center justify-center p-4 selection:bg-white select-none\">\n      <div className=\"liquid-glass w-full max-w-lg border border-white/10 rounded-2xl overflow-hidden shadow-2xl animate-fade-rise duration-300\">\n        \n        {/* Header bar */}\n        <div className=\"flex justify-between items-center px-6 py-5 border-b border-white/5 bg-white/1\">\n          <div>\n            <span className=\"font-display text-2xl text-white tracking-wide\">Align Our Vision</span>\n            <p className=\"text-[10px] font-mono text-muted-foreground uppercase mt-1 tracking-widest\">SUBMIT COUPLING COORD</p>\n          </div>\n          <button\n            id=\"contact-close-btn\"\n            onClick={onClose}\n            className=\"w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center text-muted-foreground hover:text-white transition-all cursor-pointer\"\n            title=\"Dismiss interface\"\n          >\n            <X className=\"w-4 h-4\" />\n          </button>\n        </div>\n\n        {/* Form area */}\n        <div className=\"p-6\">\n          {submitted ? (\n            <div className=\"text-center py-12 flex flex-col items-center justify-center gap-4 animate-pulse\">\n              <div className=\"w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400\">\n                <Check className=\"w-6 h-6\" />\n              </div>\n              <p className=\"font-display text-xl text-white\">Transmission Broadcasted</p>\n              <p className=\"text-xs text-muted-foreground font-mono max-w-xs uppercase tracking-widest leading-relaxed\">\n                System matched. Your inquiry has been routed into Jo\303\243o\'s backlog queue. \n              </p>\n              <span className=\"text-[9px] text-[#34d399] font-mono\">STATUS: EMITTED</span>\n            </div>\n          ) : (\n            <form onSubmit={handleSubmit} className=\"flex flex-col gap-4\">\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"flex flex-col gap-1.5 text-left\">\n                  <label htmlFor=\"contact-name\" className=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\">Identifier / Name</label>\n                  <input\n                    id=\"contact-name\"\n                    type=\"text\"\n                    required\n                    value={name}\n                    onChange={(e) => setName(e.target.value)}\n                    placeholder=\"E.g., Dr. Alice\"\n                    className=\"bg-white/3 border border-white/5 focus:border-white/30 rounded-lg px-3 py-2 text-sm text-white focus:outline-none transition-all placeholder:text-stone-600 font-sans\"\n                  />\n                </div>\n                <div className=\"flex flex-col gap-1.5 text-left\">\n                  <label htmlFor=\"contact-email\" className=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\">Coupling Matrix / Email</label>\n                  <input\n                    id=\"contact-email\"\n                    type=\"email\"\n                    required\n                    value={email}\n                    onChange={(e) => setEmail(e.target.value)}\n                    placeholder=\"name@example.com\"\n                    className=\"bg-white/3 border border-white/5 focus:border-white/30 rounded-lg px-3 py-2 text-sm text-white focus:outline-none transition-all placeholder:text-stone-600 font-sans\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 text-left\">\n                <label className=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\">Inquiry Paradigm</label>\n                <div className=\"grid grid-cols-3 gap-2\">\n                  {[\n                    \"Digital Client\",\n                    \"Pulpit Ministry\",\n                    \"Engineering Align\"\n                  ].map((cat) => (\n                    <button\n                      id={`inquiry-cat-btn-${cat.replace(/\\s+/g, \'-\').toLowerCase()}`}\n                      key={cat}\n                      type=\"button\"\n                      onClick={() => setCategory(cat)}\n                      className={`py-2 px-1 text-[11px] rounded-lg border font-mono transition-all text-center cursor-pointer ${\n                        category === cat\n                          ? \"bg-white text-black border-white font-medium\"\n                          : \"bg-white/2 border-white/5 text-muted-foreground hover:bg-white/5 hover:text-white\"\n                      }`}\n                    >\n                      {cat}\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              <div className=\"flex flex-col gap-1.5 text-left\">\n                <label htmlFor=\"contact-message\" className=\"text-[9px] font-mono text-muted-foreground uppercase tracking-widest\">Inquiry Message</label>\n                <textarea\n                  id=\"contact-message\"\n                  required\n                  rows={4}\n                  value={message}\n                  onChange={(e) => setMessage(e.target.value)}\n                  placeholder=\"Tell me about your structural goals or street teaching collaborative scope...\"\n                  className=\"bg-white/3 border border-white/5 focus:border-white/30 rounded-lg px-3 py-2 text-sm text-white focus:outline-none transition-all placeholder:text-stone-600 font-sans resize-none\"\n                />\n              </div>\n\n              <button\n                id=\"contact-submit-btn\"\n                type=\"submit\"\n                className=\"w-full mt-2 liquid-glass text-white text-xs py-3 rounded-full hover:scale-[1.02] active:scale-95 transition-all font-mono uppercase tracking-widest flex items-center justify-center gap-1.5 cursor-pointer border-none\"\n              >\n                <Send className=\"w-3.5 h-3.5\" /> Initialize Connection Link\n              </button>\n\n              <div className=\"flex items-center justify-between border-t border-white/5 pt-4 mt-2\">\n                <span className=\"text-[9px] font-mono text-muted-foreground/50\">PREFER INSTANT DECK?</span>\n                <a\n                  id=\"contact-ig-link\"\n                  href=\"https://www.instagram.com/joao.brito_\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\"\n                  className=\"flex items-center gap-1.5 text-xs text-white hover:text-rose-400 transition-colors bg-white/5 px-3 py-1.5 rounded-full font-mono scale-95\"\n                >\n                  <Instagram className=\"w-3.5 h-3.5\" /> INSTAGRAM DIRECT\n                </a>\n              </div>\n            </form>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
