          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    Investiga\303\247\303\243o acad\303\251mica, modela\303\247\303\243o e simula\303\247\303\243o de circuitos de corrente e an\303\241lise de transit\303\263rios com integridade f\303\255sica."
